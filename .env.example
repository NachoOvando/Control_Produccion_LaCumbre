# Base de datos PostgreSQL (Supabase en producción)
# DATABASE_URL: la usa el runtime de la app (src/lib/prisma.ts). En producción
# debe apuntar al connection pooler de Supabase (PgBouncer, puerto 6543) con
# `?pgbouncer=true` en la query string — nunca conexión directa desde runtime
# serverless (Vercel), para no agotar las conexiones de Postgres bajo carga
# concurrente. En desarrollo local contra Postgres directo, sin ese parámetro.
DATABASE_URL="postgresql://usuario:password@localhost:5432/control_produccion"

# DIRECT_URL: solo la usa el CLI de Prisma (migrate, db push, studio), vía
# prisma.config.ts — conexión directa a Postgres (puerto 5432), sin pooler.
# PgBouncer en modo transacción no soporta DDL de migraciones ni advisory
# locks. En Supabase: mismo host/usuario/password que DATABASE_URL, pero
# puerto 5432 y sin `?pgbouncer=true`. Ver ADR-014 en docs/architecture.md.
DIRECT_URL="postgresql://usuario:password@localhost:5432/control_produccion"

# NextAuth
AUTH_SECRET="genera-con-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Node environment
NODE_ENV="development"

# Modo demo (solo desarrollo — NUNCA en producción)
# Habilita el login demo. Default "false": activarlo solo mientras no haya un
# login real operativo — con DB disponible, resuelve al usuario real de
# DEMO_USER_EMAIL (ver src/lib/auth.ts), así que la password de abajo termina
# siendo una segunda contraseña válida para esa cuenta. Usar un valor random
# (ej. `openssl rand -hex 12`), nunca uno predecible.
DEMO_MODE="false"
DEMO_USER_EMAIL="demo@ejemplo.com"
DEMO_USER_PASSWORD="cambiar-esta-password"
